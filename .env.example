# MSL environment variables
# Copy this file to .env and paste real values there.
# Do not commit .env or any file containing real secrets.
#
# Naming note:
# - MSL is the project/app name in this repository.
# - ML means MercadoLibre.
# - This business flow is dual-account: Plasticov -> Maustian.

# ═══════════════════════════════════════════════════════════════════
# Runtime
# ═══════════════════════════════════════════════════════════════════

# Runtime mode: "development" (default) or "production".
# In production mode, missing required secrets fail the readiness check.
MSL_RUNTIME_MODE=

# ── VPS runtime paths (non-secret) ──────────────────────────────────
# Override only if your VPS uses different directories.
MSL_APP_DIR=
MSL_DATA_DIR=/home/sebastian/msl-data
MSL_LOG_DIR=/home/sebastian/msl-data/logs

# ═══════════════════════════════════════════════════════════════════
# DeepSeek (LLM inference)
# ═══════════════════════════════════════════════════════════════════

# DeepSeek API key for LLM inference. Required in production.
DEEPSEEK_API_KEY=

# Optional DeepSeek runtime overrides. The default model is deepseek-v4-flash.
# Leave DEEPSEEK_BASE_URL empty outside local tests or an approved compatible endpoint.
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# ═══════════════════════════════════════════════════════════════════
# MiniMax (Creative Studio — image/video generation)
# ═══════════════════════════════════════════════════════════════════

# Enable the Creative Studio agent for AI-powered content generation.
# Disabled by default until credentials are configured and CEO approves.
MSL_CREATIVE_STUDIO_ENABLED=false

# MiniMax API key for image and video generation.
# Get one at https://platform.minimax.io
MINIMAX_API_KEY=

# Optional MiniMax API host override. Read first; falls back to MINIMAX_BASE_URL.
# Use this when the API host differs from the base URL pattern.
MINIMAX_API_HOST=

# Optional MiniMax base URL override for custom endpoints or testing.
# Read as fallback when MINIMAX_API_HOST is not set.
MINIMAX_BASE_URL=

# Optional MiniMax model override. Defaults to image-01 for images and video-01 for video.
MINIMAX_IMAGE_MODEL=
MINIMAX_VIDEO_MODEL=

# Request timeout for each MiniMax API call in milliseconds. Default: 120000 (2 min).
MINIMAX_REQUEST_TIMEOUT_MS=120000

# Daily budget cap for Creative Studio in USD. Default: 5.00.
MSL_CREATIVE_STUDIO_MAX_DAILY_USD=5.00

# Per-job budget cap in USD. Default: 0.50.
MSL_CREATIVE_STUDIO_MAX_JOB_USD=0.50

# Local storage path for downloaded creative assets. Default: .msl/creative-studio/assets.
MSL_CREATIVE_STUDIO_STORAGE_PATH=.msl/creative-studio/assets

# Enable automatic ML image diagnosis for MercadoLibre channel assets. (optional, default: true)
MSL_CREATIVE_STUDIO_ML_AUTO_DIAGNOSE=true

# API token for MercadoLibre ML diagnosis service. Required when auto-diagnose is enabled. (internal)
ML_API_TOKEN=

# Maximum concurrent creative generation jobs. Default: 3. (optional)
MSL_CREATIVE_STUDIO_MAX_CONCURRENT_JOBS=3

# Minimum cooldown in milliseconds between generation jobs. Default: 2000. (optional)
MSL_CREATIVE_STUDIO_MIN_COOLDOWN_MS=2000

# Optional durable SQLite path for CreativeJobQueue persistence.
# When unset, jobs live in-memory only and are lost on restart.
MSL_CREATIVE_STUDIO_DB_PATH=

# ═══════════════════════════════════════════════════════════════════
# MercadoLibre (OAuth & API access)
# ═══════════════════════════════════════════════════════════════════

# MercadoLibre OAuth application credentials.
# These identify the MercadoLibre developer application. The two seller accounts
# are connected through OAuth and stored per account by the app; do not paste
# seller access/refresh tokens into Git.
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REDIRECT_URI=

# MercadoLibre OAuth tokens for read-only API access (listing_prices, visits, quality, etc.)
# Used by the Telegram bot for real-time business data and background ingestion worker.
# Optional — bot works without these, just without ML data tools.
MERCADOLIBRE_ACCESS_TOKEN=
MERCADOLIBRE_REFRESH_TOKEN=
MERCADOLIBRE_SELLER_ID=

# Source seller access token for dual-account sync flows (Plasticov).
# Alternative to MERCADOLIBRE_ACCESS_TOKEN when dual-account OAuth is configured.
MERCADOLIBRE_SOURCE_ACCESS_TOKEN=

# Durable SQLite database used by the MCP runtime OAuth token store.
# Required for production MCP MercadoLibre reads.
MSL_MERCADOLIBRE_OAUTH_DB_PATH=

# ── MercadoLibre dual OAuth apps (per-seller) ──────────────────────
# When set, these take priority over the legacy single-app vars above.
# Source (Plasticov) OAuth app credentials.
MERCADOLIBRE_SOURCE_CLIENT_ID=
MERCADOLIBRE_SOURCE_CLIENT_SECRET=
MERCADOLIBRE_SOURCE_REDIRECT_URI=
# Target (Maustian) OAuth app credentials.
MERCADOLIBRE_TARGET_CLIENT_ID=
MERCADOLIBRE_TARGET_CLIENT_SECRET=
MERCADOLIBRE_TARGET_REDIRECT_URI=
# Secret for HMAC state signing in OAuth callback flow.
MSL_OAUTH_STATE_SECRET=

# Dual-account seller identifiers used by local wiring/sync flows.
# Use the real MercadoLibre user/account identifiers after OAuth connection.
MERCADOLIBRE_SOURCE_SELLER_ID=
MERCADOLIBRE_TARGET_SELLER_ID=

# ═══════════════════════════════════════════════════════════════════
# Telegram Bot
# ═══════════════════════════════════════════════════════════════════

# Token from @BotFather (https://t.me/BotFather).
# Create a bot with /newbot, then paste the token here.
# Format: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=

# Comma-separated Telegram chat IDs allowed admin access.
# Example: "12345678,87654321"
MSL_TELEGRAM_ADMIN_CHAT_IDS=
MSL_TELEGRAM_ADMIN_USER_IDS=

# Optional durable Telegram session/strategy/autonomy database.
# When set, @msl/bot persists each Telegram chat under a seller-scoped session id.
MSL_TELEGRAM_SQLITE_PATH=

# Optional Cortex graph database for Telegram Escribano memory writes.
# Set this when Telegram turns should update Cortex memory. The bot derives a
# seller-scoped SQLite filename from this path before opening Cortex.
MSL_TELEGRAM_CORTEX_SQLITE_PATH=

# Optional explicit active company-agent identity for Telegram conversations.
# When unset or invalid/inactive, AgentLoop fails closed and injects no workforce lessons.
# This does not grant Telegram admin authorization.
MSL_TELEGRAM_ACTIVE_COMPANY_AGENT_ID=

# Optional admin gate for company-agent management tools in Telegram runtime.
# Active company-agent routing above is context selection only; admin tools require
# this flag plus at least one allowlisted Telegram chat/user id.
MSL_COMPANY_AGENT_ADMIN_ENABLED=

# ═══════════════════════════════════════════════════════════════════
# Persistence (SQLite databases)
# ═══════════════════════════════════════════════════════════════════

# Optional durable chat state database. When set, /api/chat persists session,
# strategy, and autonomy state in SQLite and may use real DeepSeek if configured.
# Requires MSL_CHAT_SELLER_ID to be set to a non-demo seller id.
MSL_CHAT_SQLITE_PATH=

# Alternative SQLite path for agent message bus persistence.
# Can be used instead of MSL_CHAT_SQLITE_PATH for agent communication storage.
MSL_AGENT_BUS_DB_PATH=

# Durable SQLite database used by the MCP approval queue.
MSL_APPROVAL_QUEUE_DB_PATH=

# Shared Cortex graph database path for runtimes that support direct Cortex access.
# Telegram also seller-scopes this path before opening Cortex when no
# MSL_TELEGRAM_CORTEX_SQLITE_PATH is set.
MSL_CORTEX_SQLITE_PATH=

# ═══════════════════════════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════════════════════════

# Secret used to derive the local OAuth token encryption key.
# Use a long random value. Changing it can make previously encrypted tokens unreadable.
MSL_ENCRYPTION_KEY=

# Local/demo escape hatch for token encryption when no real tokens are stored.
# Leave false/blank outside local development.
MSL_ALLOW_INSECURE_DEV_SECRETS=

# Local/demo escape hatch. Leave false/blank outside local development.
MSL_ALLOW_UNAUTHENTICATED_LOCAL=

# Bearer token required by apps/web /api/chat when set.
# Send requests with: Authorization: Bearer <MSL_API_KEY>
MSL_API_KEY=

# Operator/browser access token for /conversacion. The browser submits this to
# receive an HttpOnly same-site cookie; it is never exposed as a public env var.
MSL_CONVERSATION_ACCESS_TOKEN=

# API key expected by the MCP server tools when set.
MSL_MCP_API_KEY=

# Optional chat identity overrides.
MSL_CHAT_SELLER_NAME=Plasticov
MSL_CHAT_SELLER_ID=

# ═══════════════════════════════════════════════════════════════════
# Supplier Mirror / Jinpeng
# ═══════════════════════════════════════════════════════════════════

# Seller identifiers used by Jinpeng bootstrap and supplier mirror runtime.
MSL_PLASTICOV_SELLER_ID=
MSL_MAUSTIAN_SELLER_ID=

# Path to the Supplier Mirror SQLite database.
MSL_SUPPLIER_MIRROR_DB_PATH=

# Enable the Supplier Mirror background worker scheduler.
# Keep disabled (false/empty) until Jinpeng dry-run passes and CEO approves.
MSL_SUPPLIER_MIRROR_WORKER_ENABLED=

# Jinpeng supplier identity (ML seller ID or nickname required).
MSL_JINPENG_ML_SELLER_ID=
MSL_JINPENG_ML_NICKNAME=

# Optional Jinpeng profile URL for supporting evidence.
MSL_JINPENG_ML_PROFILE_URL=

# XKP enrichment source URL (not stock authority).
MSL_JINPENG_XKP_URL=
