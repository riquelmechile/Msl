# MSL environment variables
# Copy this file to .env.local and paste real values there.
# Do not commit .env.local or any file containing real secrets.

# Naming note:
# - MSL is the project/app name in this repository.
# - ML means MercadoLibre.
# - This business flow is dual-account: Plasticov -> Maustian.

# DeepSeek API key used by the real LLM client.
DEEPSEEK_API_KEY=

# Bearer token required by apps/web /api/chat when set.
# Send requests with: Authorization: Bearer <MSL_API_KEY>
MSL_API_KEY=

# Operator/browser access token for /conversacion. The browser submits this to
# receive an HttpOnly same-site cookie; it is never exposed as a public env var.
MSL_CONVERSATION_ACCESS_TOKEN=

# Local/demo escape hatch. Leave false/blank outside local development.
MSL_ALLOW_UNAUTHENTICATED_LOCAL=

# Optional durable chat state database. When set, /api/chat persists session,
# strategy, and autonomy state in SQLite and may use real DeepSeek if configured.
# Requires MSL_CHAT_SELLER_ID to be set to a non-demo seller id.
MSL_CHAT_SQLITE_PATH=

# Optional durable Telegram session/strategy/autonomy database.
# When set, @msl/bot persists each Telegram chat under a seller-scoped session id.
MSL_TELEGRAM_SQLITE_PATH=

# Optional Cortex graph database for Telegram Escribano memory writes.
# Set this when Telegram turns should update Cortex memory. The bot derives a
# seller-scoped SQLite filename from this path before opening Cortex.
MSL_TELEGRAM_CORTEX_SQLITE_PATH=

# Shared Cortex graph database path for runtimes that support direct Cortex access.
# Telegram also seller-scopes this path before opening Cortex when no
# MSL_TELEGRAM_CORTEX_SQLITE_PATH is set.
MSL_CORTEX_SQLITE_PATH=

# Optional chat identity overrides.
MSL_CHAT_SELLER_NAME=Plasticov
MSL_CHAT_SELLER_ID=

# API key expected by the MCP server tools when set.
MSL_MCP_API_KEY=

# Durable SQLite database used by the MCP approval queue.
MSL_APPROVAL_QUEUE_DB_PATH=

# Secret used to derive the local OAuth token encryption key.
# Use a long random value. Changing it can make previously encrypted tokens unreadable.
MSL_ENCRYPTION_KEY=

# Local/demo escape hatch for token encryption when no real tokens are stored.
# Leave false/blank outside local development.
MSL_ALLOW_INSECURE_DEV_SECRETS=

# MercadoLibre OAuth application credentials.
# These identify the MercadoLibre developer application. The two seller accounts
# are connected through OAuth and stored per account by the app; do not paste
# seller access/refresh tokens into Git.
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REDIRECT_URI=

# MercadoLibre OAuth tokens for read-only API access (listing_prices, visits, quality, etc.)
# Used by the Telegram bot for real-time business data and background ingestion worker.
# Optional — bot works without these, just without ML data tools.
MERCADOLIBRE_ACCESS_TOKEN=
MERCADOLIBRE_REFRESH_TOKEN=
MERCADOLIBRE_SELLER_ID=

# Durable SQLite database used by the MCP runtime OAuth token store.
# Required for production MCP MercadoLibre reads.
MSL_MERCADOLIBRE_OAUTH_DB_PATH=

# Dual-account seller identifiers used by local wiring/sync flows.
# Use the real MercadoLibre user/account identifiers after OAuth connection.
MERCADOLIBRE_SOURCE_SELLER_ID=
MERCADOLIBRE_TARGET_SELLER_ID=

# Optional explicit role aliases for deployments/secrets dashboards.
# Keep them aligned with MERCADOLIBRE_SOURCE_SELLER_ID and MERCADOLIBRE_TARGET_SELLER_ID.
PLASTICOV_SELLER_ID=
MAUSTIAN_SELLER_ID=

# ── Telegram Bot ────────────────────────────────────────
# Token from @BotFather (https://t.me/BotFather).
# Create a bot with /newbot, then paste the token here.
# Format: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=
