# Auto detect text files and perform LF normalization
* text=auto

# TypeScript/JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Config files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf

# Shell scripts
*.sh text eol=lf

# CI
.github/workflows/*.yml text eol=lf
