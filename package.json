{
  "name": "msl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @msl/web",
    "build": "tsc -b && npm run build --workspace @msl/web",
    "typecheck": "tsc -b --pretty false && npm run typecheck --workspace @msl/web",
    "start:bot": "node scripts/start-bot.mjs",
    "start:web": "npm run start --workspace @msl/web",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.mjs",
    "smoke:deepseek:tool": "npm run build --workspace @msl/agent && node scripts/deepseek-tool-smoke.mjs",
    "check:production-secrets": "npm run build --workspace @msl/agent && node scripts/check-production-secrets.mjs",
    "production:readiness": "npx tsx packages/agent/src/readiness/cli.ts",
    "meli:connection:status": "npx tsx packages/mercadolibre/src/connection/cli.ts status",
    "meli:refresh": "npx tsx packages/mercadolibre/src/connection/cli.ts refresh",
    "meli:smoke": "npx tsx packages/mercadolibre/src/connection/cli.ts smoke",
    "meli:connect:url": "npx tsx packages/mercadolibre/src/connection/cli.ts connect-url",
    "supplier-mirror:jinpeng:dry-run": "npm run build --workspace @msl/workers && node scripts/supplier-mirror-jinpeng-bootstrap.mjs --dry-run",
    "seed:account-assets": "node scripts/seed-account-assets.mjs",
    "lint": "TSESTREE_SINGLE_RUN=true eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "economic:ingest": "npx tsx packages/agent/src/cli/economicCli.ts ingest",
    "economic:status": "npx tsx packages/agent/src/cli/economicCli.ts status",
    "economic:coverage": "npx tsx packages/agent/src/cli/economicCli.ts coverage",
    "economic:reconcile": "npx tsx packages/agent/src/cli/economicCli.ts reconcile",
    "economic:missing": "npx tsx packages/agent/src/cli/economicCli.ts missing"
  },
  "dependencies": {
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.6.2",
    "rollup": "npm:@rollup/wasm-node@^4.62.2",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "better-sqlite3@12.11.1": true,
    "unrs-resolver@1.12.2": true
  }
}
