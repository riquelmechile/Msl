    "findings": [
      {
        "id": "RISK-001",
        "lens": "RISK",
        "location": "openspec/changes/finalize-economic-run-consistency/migration-plan.md:10-15; openspec/changes/finalize-economic-run-consistency/specs/migration-framework/spec.md:7-12",
        "severity": "CRITICAL",
        "claim": "Migrations 1007-1009 deterministically precede fence migration 1010, so those migration writers cannot satisfy the design's fence-validation requirement while the fence does not yet exist.",
        "proof_refs": [
          "migration-plan.md:10-13 orders 1007 checkpoints/health, 1008 leases/backlog, 1009 alerts, then 1010 metadata/fence.",
          "migration-framework/spec.md:7-12 requires adding and applying 1007-1010 in that order."
        ]
      },
      {
        "id": "RISK-002",
        "lens": "RISK",
        "location": "openspec/changes/finalize-economic-run-consistency/operations-restore-alert-policy.md:12-13; openspec/changes/finalize-economic-run-consistency/rollback-plan.md:5",
        "severity": "CRITICAL",
        "claim": "The deterministic post-swap rollback path restores the retained candidate without requiring closure of the newly reopened restored handle or removal of the restored database WAL/SHM sidecars.",
        "proof_refs": [
          "operations-restore-alert-policy.md:12 reopens a new handle before post-swap validation.",
          "operations-restore-alert-policy.md:13 restores the retained candidate on validation failure but specifies neither closing that reopened handle nor removing WAL/SHM sidecars."
        ]
      },
      {
        "id": "RISK-003",
        "lens": "RISK",
        "location": "openspec/changes/finalize-economic-run-consistency/operations-restore-alert-policy.md:11-15; openspec/changes/finalize-economic-run-consistency/specs/migration-framework/spec.md:14-21",
        "severity": "CRITICAL",
        "claim": "Restore validation deterministically lacks an immutable match between the backup manifest's tenant/economic database identity and the live target identity before swap.",
        "proof_refs": [
          "operations-restore-alert-policy.md:11 validates integrity, registry, and metadata but does not require tenant or economic database identity equality.",
          "operations-restore-alert-policy.md:15 records a generic manifest identity and safe path identifier without defining or comparing an immutable tenant/economic database identity."
        ]
      },
      {
        "id": "RISK-004",
        "lens": "RISK",
        "location": "openspec/changes/finalize-economic-run-consistency/reconciliation-checkpoint-policy.md:3-7",
        "severity": "CRITICAL",
        "claim": "The post-rollback operational transaction may be admitted without the original admission generation/token, allowing an inferred stale operation to persist state across a fence generation change.",
        "proof_refs": [
          "reconciliation-checkpoint-policy.md:3 requires admission to record the open fence generation/token for normal writers.",
          "reconciliation-checkpoint-policy.md:7 says the separate transaction validates fence state but does not require the lost lease and does not state that it validates the admission generation/token."
        ]
      },
      {
        "id": "RESILIENCE-001",
        "lens": "RESILIENCE",
        "location": "openspec/changes/finalize-economic-run-consistency/fetch-data-quality-policy.md:7-11; openspec/changes/finalize-economic-run-consistency/operations-restore-alert-policy.md:5,23; openspec/changes/finalize-economic-run-consistency/migration-plan.md:19-33",
        "severity": "CRITICAL",
        "claim": "Lease and fence TTL, renewal timing, expiry ownership, and recovery behavior are deterministically absent despite persisted expiry fields and required expiry recovery.",
        "proof_refs": [
          "fetch-data-quality-policy.md:7-11 defines due/lease fields and acquire/renew/release but no TTL or renewal cadence.",
          "operations-restore-alert-policy.md:23 requires expired backlog lease recovery without defining timing.",
          "migration-plan.md:26 and 33 define alert claim expiry and a fence row but no bounded TTL/recovery timing."
        ]
      },
      {
        "id": "RESILIENCE-002",
        "lens": "RESILIENCE",
        "location": "openspec/changes/finalize-economic-run-consistency/reconciliation-checkpoint-policy.md:5-7; openspec/changes/finalize-economic-run-consistency/operations-restore-alert-policy.md:26",
        "severity": "CRITICAL",
        "claim": "A deterministic crash window exists after the failed final transaction rolls back and before the separate operational transaction durably records the failed run, CAS detail, health, and alert intent.",
        "proof_refs": [
          "reconciliation-checkpoint-policy.md:5 requires missing or retry-exhausted CAS to roll back the final transaction.",
          "reconciliation-checkpoint-policy.md:7 persists failure evidence only afterward in a separate transaction, leaving an unjournaled interval between transactions."
        ]
      },
      {
        "id": "RESILIENCE-003",
        "lens": "RESILIENCE",
        "location": "openspec/changes/finalize-economic-run-consistency/operations-restore-alert-policy.md:9-15; openspec/changes/finalize-economic-run-consistency/specs/migration-framework/spec.md:14-21",
        "severity": "CRITICAL",
        "claim": "The deterministic two-rename restore sequence has no durable phase journal or startup recovery contract for a crash between retaining the live file and promoting staging.",
        "proof_refs": [
          "operations-restore-alert-policy.md:12 specifies rename live to retained candidate followed by rename staging to live.",
          "operations-restore-alert-policy.md:9-15 defines no durable restore phase record or startup reconciliation for interruption between the two renames."
        ]
      },
      {
        "id": "RESILIENCE-004",
        "lens": "RESILIENCE",
        "location": "openspec/changes/finalize-economic-run-consistency/operations-restore-alert-policy.md:3-5,28; openspec/changes/finalize-economic-run-consistency/migration-plan.md:19-33",
        "severity": "CRITICAL",
        "claim": "Alert dispatch deterministically lacks bounded visibility objectives and an independent paging fallback when its transport degrades or records dead-letter.",
        "proof_refs": [
          "operations-restore-alert-policy.md:5 names bounded backoff, dead-letter, and degraded readiness but provides no delivery/dead-letter time objective or paging fallback.",
          "migration-plan.md:22-33 defines durable alert lifecycle fields without bounded dispatch visibility objectives or a separate fallback channel."
        ]
      },
      {
        "id": "READABILITY-001",
        "lens": "READABILITY",
        "location": "openspec/changes/finalize-economic-run-consistency/review-framework-incident.md:27-31; openspec/changes/finalize-economic-run-consistency/tasks.md:73; openspec/changes/finalize-economic-run-consistency/specs/migration-framework/spec.md:23-25",
        "severity": "CRITICAL",
        "claim": "Review documents deterministically conflict over whether a positive refuter counter is mandatory when no genuine inferential severe finding exists, preventing one unambiguous acceptance rule.",
        "proof_refs": [
          "review-framework-incident.md:29 says a refuter batch runs only when pending inferential severe candidates exist.",
          "review-framework-incident.md:31 says a demanded positive counter blocks PASS when none exist, while tasks.md:73 and migration-framework/spec.md:23-25 state the conditional rule as the R8 acceptance contract."
        ]
      },
      {
        "id": "READABILITY-002",
        "lens": "READABILITY",
        "location": "openspec/changes/finalize-economic-run-consistency/fetch-data-quality-policy.md:7-11; openspec/changes/finalize-economic-run-consistency/tasks.md:69-70",
        "severity": "CRITICAL",
        "claim": "The intended lease duration and renewal cadence are inferential because the design requires short leases, expiry recovery, and renewal tests without specifying concrete timing values or bounds.",
        "proof_refs": [
          "fetch-data-quality-policy.md:7-11 defines lease fields, expiry behavior, and renew operations without duration or cadence.",
          "tasks.md:69-70 requires short leases, expiry recovery, and fake-clock renewal coverage without giving implementable timing bounds."
        ]
      },
      {
        "id": "RELIABILITY-001",
        "lens": "RELIABILITY",
        "location": "openspec/changes/finalize-economic-run-consistency/reconciliation-checkpoint-policy.md:3-9; openspec/changes/finalize-economic-run-consistency/tasks.md:68-72",
        "severity": "CRITICAL",
        "claim": "Release-fence behavior is inferentially under-tested because acceptance does not explicitly cover release under generation/token mismatch, expiry, ownership loss, and restore-state transitions.",
        "proof_refs": [
          "reconciliation-checkpoint-policy.md:3 requires lease release to validate the admission fence generation/token.",
          "tasks.md:68-72 covers fenced writer rejection and fence checks broadly but provides no explicit release-fence acceptance matrix for mismatch, expiry, ownership loss, and restore transitions."
        ]
      },
      {
        "id": "RELIABILITY-002",
        "lens": "RELIABILITY",
        "location": "openspec/changes/finalize-economic-run-consistency/operations-restore-alert-policy.md:3-5; openspec/changes/finalize-economic-run-consistency/tasks.md:72",
        "severity": "CRITICAL",
        "claim": "Hostile alert payload sanitization and expired dispatcher-claim recovery are inferentially missing from the explicit acceptance tests.",
        "proof_refs": [
          "operations-restore-alert-policy.md:5 requires allowlisted sanitized payloads and says claim expiry returns work to retrying.",
          "tasks.md:72 lists alert lifecycle coverage but does not explicitly require hostile payload cases or expired claim recovery races."
        ]
      }
    ],
